{
  "ignore": {
    "unused": [],
    "outdated": [],
    "duplicates": [],
    "risks": [],
    "dependencies": [],
    "devDependencies": [],
    "prefixes": [],
    "patterns": []
  },
  "policy": {
    "minScore": 85,
    "failOnUnused": false,
    "failOnOutdated": false,
    "failOnDuplicates": false,
    "failOnRisks": false
  },
  "report": {
    "maxSuggestions": 5
  },
  "scoring": {
    "duplicateWeight": 5,
    "outdatedWeight": 3,
    "unusedWeight": 4,
    "riskWeight": 10
  },
  "scan": {
    "excludePaths": ["node_modules", "dist", "build", "coverage", ".git"]
  }
}
